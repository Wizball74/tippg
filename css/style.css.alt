#bLogin { width: 120px; height: 30px; }
#login_loading { display: none; }
#login_response { display: none; color: red;text-align: center;margin-top: 10px; }

.navtr select { margin-right:0.5em; border-radius:4px; margin:1px;}
.navtr button:first-of-type { margin-left:0.5em;}
.navtr { display:none; }

.content { margin-right:0.5em; margin-bottom:0.5em;}

#msg { margin-bottom: 1em;}

.error {
	border:solid 2px red;  
    padding: 5px 5px 5px 25px;
    border-radius:5px;
	color: red;
	background: url(images/error.png) no-repeat 5px 5px;
	margin: 5px 0 5px 20px;
}

.status {
	border:solid 2px green; 
    padding: 5px 5px 5px 25px;
    border-radius:5px;
	color: #333333;
	background: url(images/ok.png) no-repeat 5px 5px;
	margin: 5px 0 5px 20px;
}


.kttable,
.kttable .rounded { border: 0 none; } 
.kttable th { font-weight: normal; padding:4px 2px; }
.kttable td { font-weight: normal; padding:2px; }

.kttable td.Date { width:60px;}
.kttable td.Team { width:250px;}
.kttable td.Result { width:60px;}
.kttable .bold  { font-weight: bold; }

.ui-state-default .ui-icon.icon-print { background-image: url(images/print.png); }
.ui-state-default .ui-icon.icon-disk { background-image: url(images/save.png); }
.ui-state-default .ui-icon.icon-start { background-image: url(images/action_go.png); }

/**** Grids **************************************************************************/
.ui-jqgrid th { font-size: 0.9em; }
.ui-jqgrid td { font-size: 0.95em; }

.ui-jqgrid p { margin:0;}
.ui-jqgrid .ui-jqgrid-htable .ui-th-div { height: auto; }
.ui-th-column, .ui-jqgrid .ui-jqgrid-htable th.ui-th-column { text-align: center; }
 
.ui-jqgrid [role=gridcell] { padding:2px; }
.ui-jqgrid span.deadline { font-weight: bold;color: red;float: none;display: inline; margin-right:1em;}

.ui-jqgrid .ui-jqgrid-title { font-weight:bold;}

/*
div.ui-jqgrid.ui-widget-content,
tr.ui-widget-content { background: none; }
*/
/* div.ui-jqgrid tr.ui-state-hover td { background: none; /* IE * //*	font-weight: bold;* / } */
