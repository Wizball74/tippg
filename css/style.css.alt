@media (min-width: 1600px) {
  .container {
    width: 1570px;
  }
}

@media (max-width: 767px) {
    .ktcontent { padding:0 1px; }

    .navbar-brand { display:none; }

    .ktgrid { padding:0 1px; }


    .ui-jqgrid td.Team { font-size: 0.85em;}
    .ui-jqgrid td.Name { font-size: 0.85em;}
    .ui-jqgrid td.Date { font-size: 0.8em;}
    .ui-jqgrid td.Time { font-size: 0.8em;}

    .ui-userdata-top { display: none; }
    .ui-userdata-top.btn { display: block; }
}
