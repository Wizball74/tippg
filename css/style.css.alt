.ui-jqgrid tr.jqgrow.bldit td,
tbody tr.bldit td { font-style: italic; font-weight: bold; }
div.ui-jqgrid tr.ui-state-hover { background: 0 none; }
.ui-jqgrid-sdiv tr:last-child td:last-child { border-radius: 0 0 10px 0; }

.ui-jqgrid .ui-jqgrid-pager.ui-jqgrid-toolbar { height: 28px;}
.ui-jqgrid .ui-jqgrid-toolbar td { margin-right: 5px; }
.ui-jqgrid .ui-jqgrid-toolbar .ui-pg-selbox { height: 24px;padding: 2px; }
.ui-jqgrid .ui-jqgrid-toolbar .ui-pg-input  {height: 18px;font-size: 0.9em;padding: 1px 2px; }
*/

.ui-jqgrid tr.ui-row-ltr td { border-right: 1px dotted; }

.ui-jqgrid td input, 
.ui-jqgrid td select,
.ui-jqgrid td textarea 
{
	margin: 2%;
	padding: 1px 3px;
	width: 95%;
	border-radius: 4px;
	font-size: 0.95em;
}

.ui-jqgrid td.Date { font-size: 0.9em;}
.ui-jqgrid td.Time { font-size: 0.9em;}

.ui-jqgrid td.Pos { font-weight: bold;}
.ui-jqgrid td.Pts { font-weight: bold;}
.ui-jqgrid td.Pts1 { font-weight: bold; font-size: 0.9em;}
.ui-jqgrid td.Bonus { font-weight: bold;}
.ui-jqgrid td.Result { font-weight: bold;}
.ui-jqgrid p.hdrRes{ font-weight: bold;}

.btnGrid {
	font-weight: bold;
	border: 1px solid #111111;    
	-moz-box-shadow:1px 1px 2px #999999;
	-webkit-box-shadow:1px 2px 1px #999999;
	box-shadow:1px 1px 2px #999999;	
	-moz-border-radius:6px;
	-webkit-border-radius:6px;
	border-radius:6px;
	cursor: pointer;   
	padding: 1px 2px;
	font-size: 0.9em !important;
	margin: 2px 2px !important;
}
	
.btnGrid img { height: 12px; }
.ui-jqgrid .btnGrid span { display: block; margin: 1px 6px 1px 2px; float:left;}
.ui-jqgrid-toolbar .btnGrid  { padding: 1px 4px; }

.btnGridImg {
	color: #FFFFFF;
	font-weight: bold;
	background: transparent;
	border: 0 none;    
	cursor: pointer;
	padding: 0;
	font-size: 0.9em !important;
	margin: 2px 4px 1px 2px !important;
}
.btnGridImg img { height: 16px; }

/* Logos */
.logo {
    background-image: url("images/logos.png");
    background-repeat: no-repeat;
    top: 0;
    left: 0;
    height: 18px;
    width: 18px;
    overflow: hidden;
    position: relative;
    float: left;   
}

.ui-jqgrid .logo { margin: 2px 0 0 1px; }

